# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Google Maps (Optional)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Environment
NODE_ENV=development

# KYC service — for production (petflik.com) set to your live KYC URL, e.g.:
# VITE_KYC_API_URL=https://your-kyc.up.railway.app
# For local dev the proxy uses port 8002; override if needed:
# VITE_KYC_PROXY_TARGET=http://127.0.0.1:8002

# Admin dashboard (simple password protection; client checks VITE_ var)
ADMIN_PASSWORD=your_admin_password_here
VITE_ADMIN_PASSWORD=your_admin_password_here
